set_input_delay -clock i_clk  300  [get_ports {i_op_mode[1]}]
set_input_delay -clock i_clk  300  [get_ports {i_op_mode[0]}]
set_input_delay -clock i_clk  300  [get_ports i_in_valid]
set_input_delay -clock i_clk  300  [get_ports {i_in_data[23]}]
