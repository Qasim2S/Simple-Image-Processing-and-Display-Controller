set_input_delay -clock i_clk  300  [get_ports {i_in_data[1]}]
set_input_delay -clock i_clk  300  [get_ports {i_in_data[0]}]
set_output_delay -clock i_clk  300  [get_ports o_op_ready]
set_output_delay -clock i_clk  300  [get_ports o_in_ready]
set_output_delay -clock i_clk  300  [get_ports o_out_valid]
set_output_delay -clock i_clk  300  [get_ports {o_out_data[23]}]
set_output_delay -clock i_clk  300  [get_ports {o_out_data[22]}]
