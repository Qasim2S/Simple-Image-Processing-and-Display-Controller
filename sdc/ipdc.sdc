###################################################################

# Created by write_sdc on Sat Apr  4 18:12:02 2026

###################################################################
set sdc_version 2.1

set_units -time ps -resistance kOhm -capacitance fF -voltage V -current mA
set_max_area 0
create_clock [get_ports i_clk]  -period 2000  -waveform {0 1000}
set_false_path   -from [get_ports i_rst_n]
set_input_delay -clock i_clk  300  [get_ports i_clk]
set_input_delay -clock i_clk  300  [get_ports i_rst_n]
set_input_delay -clock i_clk  300  [get_ports i_op_valid]
set_input_delay -clock i_clk  300  [get_ports {i_op_mode[3]}]
